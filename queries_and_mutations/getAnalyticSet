query getAnalyticSet($uuid: ID!, $RBAC_Plan: Boolean!, $excludeAnalytics: Boolean = false) {
  getAnalyticSet(uuid: $uuid) {
    ...AnalyticSetFields
    __typename
  }
}

fragment AnalyticSetFields on AnalyticSet {
  uuid
  name
  description
  analytics @skip(if: $excludeAnalytics) {
    uuid
    name
    jamf
    __typename
  }
  plans @include(if: $RBAC_Plan) {
    id
    name
    __typename
  }
  created
  updated
  managed
  types
  __typename
}
