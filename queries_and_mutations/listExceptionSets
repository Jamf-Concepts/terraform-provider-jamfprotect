query listExceptionSets($nextToken: String, $direction: OrderDirection!, $field: ExceptionSetOrderField!, $filter: ExceptionSetFiltersInput, $minimal: Boolean = true, $RBAC_Analytic: Boolean!, $RBAC_Plan: Boolean!) {
  listExceptionSets(
    input: {next: $nextToken, order: {direction: $direction, field: $field}, filter: $filter, pageSize: 100}
  ) {
    items {
      ...ExceptionSetFields
      __typename
    }
    pageInfo {
      next
      total
      __typename
    }
    __typename
  }
}

fragment ExceptionSetFields on ExceptionSet {
  uuid
  name
  description
  exceptions @skip(if: $minimal) {
    type
    value
    appSigningInfo {
      appId
      teamId
      __typename
    }
    ignoreActivity
    analyticTypes
    analytic @include(if: $RBAC_Analytic) {
      name
      uuid
      __typename
    }
    __typename
  }
  esExceptions @skip(if: $minimal) {
    type
    value
    appSigningInfo {
      appId
      teamId
      __typename
    }
    ignoreActivity
    ignoreListType
    ignoreListSubType
    eventType
    __typename
  }
  created
  updated
  plans @include(if: $RBAC_Plan) {
    id
    name
    __typename
  }
  managed
  __typename
}
