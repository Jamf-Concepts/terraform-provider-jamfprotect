mutation updateActionConfigs($id: ID!, $name: String!, $description: String!, $alertConfig: ActionConfigsAlertConfigInput!, $hasLimitedAppAccess: Boolean!, $clients: [ReportClientInput!], $RBAC_Plan: Boolean!) {
  updateActionConfigs(
    id: $id
    input: {name: $name, description: $description, alertConfig: $alertConfig, clients: $clients}
  ) {
    ...ActionConfigsFields
    __typename
  }
}

fragment AlertDataConfigFields on AlertDataConfig {
  attrs
  related
  __typename
}

fragment ActionsReportClients on ReportClient {
  id
  type
  supportedReports
  batchConfig {
    delimiter
    sizeIndex
    windowInSeconds
    sizeInBytes
    __typename
  }
  params {
    ... on JamfCloudClientParams {
      destinationFilter
      __typename
    }
    ... on HttpClientParams {
      headers {
        header
        value
        __typename
      }
      method
      url
      __typename
    }
    ... on KafkaClientParams {
      host
      port
      topic
      clientCN
      serverCN
      __typename
    }
    ... on SyslogClientParams {
      host
      port
      scheme
      __typename
    }
    ... on LogFileClientParams {
      path
      permissions
      maxSizeMB
      ownership
      backups
      __typename
    }
    __typename
  }
  __typename
}

fragment AlertConfigsFields on ActionConfigsAlertConfig {
  data {
    binary {
      ...AlertDataConfigFields
      __typename
    }
    clickEvent {
      ...AlertDataConfigFields
      __typename
    }
    downloadEvent {
      ...AlertDataConfigFields
      __typename
    }
    file {
      ...AlertDataConfigFields
      __typename
    }
    fsEvent {
      ...AlertDataConfigFields
      __typename
    }
    group {
      ...AlertDataConfigFields
      __typename
    }
    procEvent {
      ...AlertDataConfigFields
      __typename
    }
    process {
      ...AlertDataConfigFields
      __typename
    }
    screenshotEvent {
      ...AlertDataConfigFields
      __typename
    }
    usbEvent {
      ...AlertDataConfigFields
      __typename
    }
    user {
      ...AlertDataConfigFields
      __typename
    }
    gkEvent {
      ...AlertDataConfigFields
      __typename
    }
    keylogRegisterEvent {
      ...AlertDataConfigFields
      __typename
    }
    mrtEvent {
      ...AlertDataConfigFields
      __typename
    }
    __typename
  }
  __typename
}

fragment ActionConfigsFields on ActionConfigs {
  id
  name
  description
  hash
  created
  updated
  alertConfig @skip(if: $hasLimitedAppAccess) {
    ...AlertConfigsFields
    __typename
  }
  clients {
    ...ActionsReportClients
    __typename
  }
  plans @include(if: $RBAC_Plan) {
    id
    name
    __typename
  }
  __typename
}
